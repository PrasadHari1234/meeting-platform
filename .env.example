# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ── AI ──────────────────────────────────────────────────────────────────────
# Anthropic: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (for Whisper transcription): https://platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# ── Auth ────────────────────────────────────────────────────────────────────
# Random secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-here

# Google OAuth: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── App ─────────────────────────────────────────────────────────────────────
# Change to your Railway URL once deployed
APP_URL=http://localhost:8000
ENVIRONMENT=development
